{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uvidnova.org/schemas/precedent.schema.json",
  "title": "uVidNova Reconstruction Precedent",
  "description": "Array of named Ukrainian reconstruction comparables used to anchor financing-structure narratives.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "precedent_id",
      "name",
      "asset_type",
      "sector",
      "oblast",
      "total_cost_usd_m",
      "grant_pct",
      "concessional_pct",
      "public_equity_pct",
      "private_pct",
      "primary_donor",
      "source_code",
      "status"
    ],
    "additionalProperties": false,
    "properties": {
      "precedent_id": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$"
      },
      "name": {
        "type": "object",
        "required": ["en"],
        "additionalProperties": false,
        "properties": {
          "en": { "type": "string" },
          "uk": { "type": "string" }
        }
      },
      "asset_type": {
        "type": "string",
        "pattern": "^[a-z_]+\\.[a-z_]+$"
      },
      "sector": {
        "type": "string",
        "enum": [
          "energy_and_power",
          "healthcare",
          "education",
          "residential",
          "heritage_and_culture",
          "transport_and_ports",
          "water_and_sanitation",
          "industrial_and_agricultural",
          "public_administration"
        ]
      },
      "oblast": { "type": "string" },
      "total_cost_usd_m": {
        "type": "number",
        "exclusiveMinimum": 0,
        "description": "Total project cost in USD millions."
      },
      "grant_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
      "concessional_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
      "public_equity_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
      "private_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
      "primary_donor": { "type": "string" },
      "source_code": {
        "type": "string",
        "enum": ["RDNA3", "KSE", "EBRD_CASE", "EU_FACILITY", "EIB_UA", "MIGA", "OCHA", "BELLINGCAT", "ACLED", "eRECOVERY"]
      },
      "source_url": {
        "type": "string",
        "format": "uri"
      },
      "status": {
        "type": "string",
        "enum": ["planned", "approved", "under_construction", "complete"]
      },
      "completion_year": {
        "type": ["integer", "null"],
        "minimum": 2022
      },
      "notes": { "type": "string" },
      "reconstruction_path": {
        "type": "string",
        "enum": ["baseline", "code_compliant", "build_back_better"]
      }
    }
  }
}
