{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uvidnova.org/schemas/financing_template.schema.json",
  "title": "uVidNova Financing Template",
  "description": "Array of standard capital-stack templates keyed by sector_group × reconstruction path. Eleven tranche layers per the Ukraine post-war financing taxonomy. Sum of tranches.*.central must equal 100 (enforced by validate-all.js). pri_wrap is a credit enhancement, not part of the sum.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "template_id",
      "sector_group",
      "path",
      "tranches",
      "pri_wrap",
      "rationale",
      "sources"
    ],
    "additionalProperties": false,
    "properties": {
      "template_id": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$",
        "description": "Unique stable ID referenced by asset financing_structures.*.template_id."
      },
      "sector_group": {
        "type": "string",
        "enum": [
          "social_infrastructure",
          "housing",
          "energy",
          "transport_revenue",
          "transport_non_revenue",
          "industrial",
          "public_administration"
        ]
      },
      "asset_type_match": {
        "type": "array",
        "description": "Glob-style patterns matching asset_type values this template applies to.",
        "items": { "type": "string" }
      },
      "path": {
        "type": "string",
        "enum": ["baseline", "code_compliant", "build_back_better"]
      },
      "tranches": {
        "type": "object",
        "required": [
          "grant_pct",
          "era_pct",
          "first_loss_pct",
          "concessional_pct",
          "senior_ifi_pct",
          "dfi_equity_pct",
          "public_equity_pct",
          "diaspora_pct",
          "commercial_debt_pct",
          "private_equity_pct"
        ],
        "additionalProperties": false,
        "properties": {
          "grant_pct":          { "$ref": "#/$defs/tranche_range" },
          "era_pct":            { "$ref": "#/$defs/tranche_range" },
          "first_loss_pct":     { "$ref": "#/$defs/tranche_range" },
          "concessional_pct":   { "$ref": "#/$defs/tranche_range" },
          "senior_ifi_pct":     { "$ref": "#/$defs/tranche_range" },
          "dfi_equity_pct":     { "$ref": "#/$defs/tranche_range" },
          "public_equity_pct":  { "$ref": "#/$defs/tranche_range" },
          "diaspora_pct":       { "$ref": "#/$defs/tranche_range" },
          "commercial_debt_pct":{ "$ref": "#/$defs/tranche_range" },
          "private_equity_pct": { "$ref": "#/$defs/tranche_range" }
        }
      },
      "pri_wrap": {
        "type": "object",
        "required": ["applicable"],
        "additionalProperties": false,
        "properties": {
          "applicable": { "type": "boolean" },
          "required": { "type": "boolean", "description": "true if PRI wrap is structurally necessary (not just optional)." },
          "providers": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["MIGA_WAR", "UKEF", "BPIFRANCE_AE", "ALLIANZ_TRADE", "EU_FACILITY_FIRST_LOSS", "EBRD_RSF", "ECA"]
            }
          }
        }
      },
      "structure_patterns": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["a_b_loan", "blending_facility", "donor_interest_rate_subsidy", "mezzanine", "ppp_concession"]
        }
      },
      "rationale": { "type": "string" },
      "comparable_projects": {
        "type": "array",
        "items": { "type": "string" }
      },
      "sources": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["code"],
          "additionalProperties": false,
          "properties": {
            "code": {
              "type": "string",
              "enum": ["RDNA3", "KSE", "EBRD_CASE", "EU_FACILITY", "EIB_UA", "MIGA", "OCHA", "BELLINGCAT", "ACLED", "eRECOVERY"]
            },
            "ref": { "type": "string" }
          }
        }
      }
    }
  },
  "$defs": {
    "tranche_range": {
      "type": "object",
      "required": ["central", "low", "high"],
      "additionalProperties": false,
      "properties": {
        "central": { "type": "integer", "minimum": 0, "maximum": 100 },
        "low":     { "type": "integer", "minimum": 0, "maximum": 100 },
        "high":    { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    }
  }
}
